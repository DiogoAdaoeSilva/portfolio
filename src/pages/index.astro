---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

// Bento layout config for the first 3 projects
const bentoLayout = [
  { colSpan: 'md:col-span-8', aspectRatio: 'aspect-[16/10]', offsetClass: '', showArrow: true, headlineSize: 'lg' as const },
  { colSpan: 'md:col-span-4', aspectRatio: 'aspect-[4/5]',   offsetClass: 'mt-12 md:mt-0', showArrow: false, headlineSize: 'sm' as const },
  { colSpan: 'md:col-span-7', aspectRatio: 'aspect-[16/9]',  offsetClass: 'mt-12 md:mt-24', showArrow: false, headlineSize: 'sm' as const },
];

const bentoProjects = sorted.slice(0, 3);
---

<BaseLayout title="VIBE — Architectural Minimalism">
  <main class="pt-32 pb-24">

    <!-- Hero: The Monolith & The Void -->
    <section class="px-8 md:px-24 mb-32">
      <div class="max-w-7xl mx-auto">
        <h1 class="text-[clamp(3.5rem,10vw,7rem)] font-bold tracking-tighter leading-[0.9] text-on-surface mb-12">
          Tectonic <br />
          <span class="text-outline-variant opacity-40">Simplicity.</span>
        </h1>
        <div class="flex flex-col md:flex-row gap-16 items-start">
          <div class="w-full md:w-1/3">
            <div class="h-[1px] w-24 bg-primary mb-8"></div>
            <p class="text-xs uppercase tracking-widest text-on-surface-variant font-bold mb-4">Philosophy</p>
            <p class="text-base text-on-surface-variant leading-relaxed">
              We view the interface as a physical architectural space. The "Monolith" represents our weighted, authoritative elements—permanent and grounded.
            </p>
          </div>
          <div class="flex-1 md:ml-auto md:max-w-xl">
            <p class="text-2xl font-medium leading-tight text-on-surface">
              Design is not merely empty space, but a deliberate "gallery" environment that gives digital content room to breathe and command authority.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Filter Bar -->
    <section class="px-8 md:px-24 mb-16">
      <div class="max-w-7xl mx-auto flex flex-wrap items-center gap-8 border-b border-outline-variant/10 pb-6">
        <span class="text-xs font-bold uppercase tracking-widest text-on-surface">Filter By:</span>
        <button class="text-sm font-bold text-on-surface border-b border-primary pb-1">All Systems</button>
        <button class="text-sm text-on-surface-variant hover:text-on-surface transition-colors">OS Design</button>
        <button class="text-sm text-on-surface-variant hover:text-on-surface transition-colors">Neural Nets</button>
        <button class="text-sm text-on-surface-variant hover:text-on-surface transition-colors">CRM Systems</button>
      </div>
    </section>

    <!-- Project Gallery: Asymmetric Bento Grid -->
    <section class="px-8 md:px-24">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6">
        {bentoProjects.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            category={`${project.data.category} / ${project.data.year}`}
            href={`/projects/${project.id}`}
            coverImage={project.data.coverImage}
            colSpan={bentoLayout[i].colSpan}
            aspectRatio={bentoLayout[i].aspectRatio}
            offsetClass={bentoLayout[i].offsetClass}
            showArrow={bentoLayout[i].showArrow}
            headlineSize={bentoLayout[i].headlineSize}
          />
        ))}

        <!-- Spacer for Asymmetry (between cards 2 and 3) -->
        <div class="hidden md:block md:col-span-1"></div>

        <!-- Text Callout -->
        <div class="md:col-span-4 flex items-end justify-start md:pb-12 mt-12 md:mt-0">
          <div class="max-w-xs">
            <span class="material-symbols-outlined text-primary text-4xl mb-6 block">architecture</span>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              Each project is a study in structural integrity. We strip away the unnecessary until only the essential logic remains.
            </p>
            <a href="/projects" class="mt-8 inline-block text-on-surface font-bold text-xs tracking-widest uppercase border-b-2 border-primary pb-1 hover:opacity-70 transition-opacity">
              View Full Archive
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="mt-32 px-8">
      <div class="max-w-7xl mx-auto bg-surface-container-low p-12 md:p-24 flex flex-col md:flex-row gap-16 items-center">
        <div class="flex-1">
          <h2 class="text-2xl font-bold tracking-tight mb-4">The Monolith Monthly.</h2>
          <p class="text-on-surface-variant text-base">Architectural insights and design updates delivered with quiet authority.</p>
        </div>
        <div class="w-full md:w-auto flex flex-col sm:flex-row gap-4">
          <input
            type="email"
            placeholder="ENTER_EMAIL"
            class="bg-surface-container-low border-b-2 border-outline-variant px-6 py-4 focus:outline-none focus:border-primary transition-colors text-on-surface font-medium min-w-[300px]"
          />
          <button class="monolith-gradient text-on-primary px-12 py-4 font-bold uppercase tracking-widest text-sm active:opacity-80 transition-opacity">
            Subscribe
          </button>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
