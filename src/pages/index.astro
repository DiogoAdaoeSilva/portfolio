---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

// Bento layout config for the first 3 projects
const bentoLayout = [
  { colSpan: 'md:col-span-8', aspectRatio: 'aspect-[16/10]', offsetClass: '', showArrow: true, headlineSize: 'lg' as const },
  { colSpan: 'md:col-span-4', aspectRatio: 'aspect-[4/5]',   offsetClass: 'mt-12 md:mt-0', showArrow: false, headlineSize: 'sm' as const },
  { colSpan: 'md:col-span-7', aspectRatio: 'aspect-[16/9]',  offsetClass: 'mt-12 md:mt-24', showArrow: false, headlineSize: 'sm' as const },
];

// Use featured projects for the bento grid; fall back to the first 3 by order
const featured = sorted.filter(p => p.data.featured);
const bentoProjects = (featured.length > 0 ? featured : sorted).slice(0, 3);
---

<BaseLayout title="VIBE — Coding Experiments">
  <main class="pt-32 pb-24">

    <!-- Hero: The Monolith & The Void -->
    <section class="px-8 md:px-24 mb-32">
      <div class="max-w-7xl mx-auto">
        <h1 class="text-[clamp(3.5rem,10vw,7rem)] font-bold tracking-tighter leading-[0.9] text-on-surface mb-12">
          Creating <br />
          <span class="text-outline-variant opacity-40">Waves.</span>
        </h1>
        <div class="flex flex-col md:flex-row gap-16 items-start">
          <div class="w-full md:w-1/3">
            <div class="h-[1px] w-24 bg-primary mb-8"></div>
            <p class="text-xs uppercase tracking-widest text-on-surface-variant font-bold mb-4">Philosophy</p>
            <p class="text-base text-on-surface-variant leading-relaxed">
              AI lets anyone build and deploy fully custom software, opening a new world of possibilities.
            </p>
          </div>
          <div class="flex-1 md:ml-auto md:max-w-xl">
            <p class="text-lg font-medium leading-tight text-on-surface">
              Collection of vibe coding experiments inspired by challenges at work and personal interests.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Project Gallery: Asymmetric Bento Grid -->
    <section class="px-8 md:px-24">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-6" id="project-grid">
        {bentoProjects.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            category={`${project.data.category} / ${project.data.year}`}
            href={`/projects/${project.id}`}
            coverImage={project.data.coverImage}
            colSpan={bentoLayout[i].colSpan}
            aspectRatio={bentoLayout[i].aspectRatio}
            offsetClass={bentoLayout[i].offsetClass}
            showArrow={bentoLayout[i].showArrow}
            headlineSize={bentoLayout[i].headlineSize}
          />
        ))}

        <!-- Spacer for Asymmetry (between cards 2 and 3) -->
        <div class="hidden md:block md:col-span-1"></div>

        <!-- Text Callout -->
        <div class="md:col-span-4 flex items-end justify-start md:pb-12 mt-12 md:mt-0">
          <div class="max-w-xs">
            <span class="material-symbols-outlined text-primary text-4xl mb-6 block">architecture</span>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              With each project a new learning.
            </p>
            <a href="/projects" class="mt-8 inline-block text-on-surface font-bold text-xs tracking-widest uppercase border-b-2 border-primary pb-1 hover:opacity-70 transition-opacity">
              View Full Archive
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

