---
/**
 * CloudinaryVideo
 * Renders a video from Cloudinary with a poster image overlay.
 *
 * Required env var: PUBLIC_CLOUDINARY_CLOUD_NAME
 *
 * Usage:
 *   <CloudinaryVideo publicId="folder/my-video" />
 *   <CloudinaryVideo publicId="folder/my-video" autoplay loop muted />
 */

interface Props {
  publicId: string;
  class?: string;
  autoplay?: boolean;
  loop?: boolean;
  muted?: boolean;
  /** Show a play-button overlay instead of native controls (good for hero sections) */
  posterMode?: boolean;
}

const {
  publicId,
  class: className,
  autoplay = false,
  loop = false,
  muted = true,
  posterMode = false,
} = Astro.props;

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const isFullUrl = publicId.startsWith('http://') || publicId.startsWith('https://');

// Extract public ID from a full Cloudinary URL, stripping version and extension
function extractPublicId(url: string): string {
  const match = url.match(/\/upload\/(?:v\d+\/)?(.+?)(?:\.[a-z0-9]+)?$/i);
  return match ? match[1] : url;
}

// Strip any file extension from the public ID (.mov, .mp4, .jpg, etc.)
function stripExtension(id: string): string {
  return id.replace(/\.[a-z0-9]+$/i, '');
}

const resolvedCloudName = isFullUrl
  ? publicId.match(/res\.cloudinary\.com\/([^/]+)/)?.[1] ?? cloudName
  : cloudName;

const resolvedId = stripExtension(
  isFullUrl ? extractPublicId(publicId) : publicId
);

function videoUrl(format: 'mp4' | 'webm'): string {
  if (!resolvedCloudName || !resolvedId) return '';
  return `https://res.cloudinary.com/${resolvedCloudName}/video/upload/f_auto,q_auto/${resolvedId}.${format}`;
}

function posterUrl(): string {
  if (!resolvedCloudName || !resolvedId) return '';
  // so_0 = snapshot at 0 seconds
  return `https://res.cloudinary.com/${resolvedCloudName}/video/upload/f_auto,q_auto,so_0/${resolvedId}.jpg`;
}

const hasSrc = Boolean(resolvedCloudName && resolvedId);
---

{hasSrc ? (
  <div class:list={["relative group overflow-hidden", className]}>
    <video
      class="w-full h-full object-cover"
      poster={posterUrl()}
      preload="metadata"
      playsinline
      autoplay={autoplay}
      loop={loop}
      muted={muted || autoplay}
      controls={!autoplay && !posterMode}
    >
      <source src={videoUrl('webm')} type="video/webm" />
      <source src={videoUrl('mp4')} type="video/mp4" />
    </video>

    {posterMode && (
      <div class="absolute inset-0 flex items-center justify-center">
        <button
          class="w-24 h-24 bg-surface-container-lowest/80 backdrop-blur-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-500"
          aria-label="Play video"
          onclick="this.closest('.group').querySelector('video').play(); this.style.display='none';"
        >
          <span
            class="material-symbols-outlined text-on-surface text-4xl"
            style="font-variation-settings: 'FILL' 1;"
          >
            play_arrow
          </span>
        </button>
      </div>
    )}
  </div>
) : (
  <div
    class:list={["bg-surface-container flex items-center justify-center text-on-surface-variant text-xs uppercase tracking-widest", className]}
    role="img"
    aria-label="Video placeholder — configure PUBLIC_CLOUDINARY_CLOUD_NAME"
  >
    <span class="material-symbols-outlined text-4xl mr-2">videocam_off</span>
    Video
  </div>
)}
